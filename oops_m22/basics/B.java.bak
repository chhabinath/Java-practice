class B
{
	static int i;
	int j;

	void inc(){
		i++;
		j++;
	}
	void display(){
		System.out.println(i+" "+j);
	}
	public static void main(String[] args) 
	{
		B b1 = new B();
		B b2 = new B();
		B b3 = new B();

		

		b1.inc();
		b1.display();
		b2.inc();
		b1.display();
		b3.inc();
		b1.display();

		
		b2.display();
		b3.display();
		
	}
}
