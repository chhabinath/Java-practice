class L 
{
	static int a;
	static double d;
	static char ch;
	static boolean b;
	static String s; //Non Premitive Datatype
	public static void main(String[] args) 
	{
		System.out.println(a);
		System.out.println(d);
		System.out.println(ch);
		System.out.println(b);
		System.out.println(s);
	}
}
