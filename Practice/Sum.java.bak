import java.util.Scanner;
class Sum 
{
	public static void main(String[] args) 
	{
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter a number");
		int n=sc.nextInt();
		//int s=0;
		for (int i=1;i<=n ;i++ )
		{
			System.out.print(i+"+");
			s+=i;
		}
		System.out.println("\b="+s);
	}
}
